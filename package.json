{
  "name": "mwbot",
  "version": "2.3.1",
  "description": "A simple, flexible MediaWiki Bot",
  "main": "src/index.js",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "p-map": "^4.0.0",
    "semlog": "^0.7.0",
    "semver": "^7.3.8",
    "tough-cookie": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "c8": "^10.0.0",
    "chai": "^4.3.7",
    "chai-as-promised": "^7.1.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0"
  },
  "scripts": {
    "lint": "eslint src/ test/",
    "format:check": "prettier --check src/ test/",
    "test": "mocha 'test/**/*.spec.js'",
    "test:coverage": "c8 mocha 'test/*.prod.spec.js'"
  },
  "mocha": {
    "timeout": 16000,
    "reporter": "spec"
  },
  "c8": {
    "reporter": [
      "lcov",
      "text",
      "clover"
    ],
    "include": [
      "src/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gesinn-it-pub/mwbot.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "MediaWiki",
    "Bot",
    "Upload",
    "API",
    "Promises",
    "MW"
  ],
  "author": {
    "name": "Simon Heimler",
    "mail": "heimlersimon@gmail.com",
    "url": "http://www.fannon.de"
  },
  "contributors": [
    {
      "name": "gesinn.it GmbH & Co. KG",
      "email": "github@gesinn.it",
      "url": "https://gesinn.it"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gesinn-it-pub/mwbot/issues"
  },
  "homepage": "https://github.com/gesinn-it-pub/mwbot#readme"
}
